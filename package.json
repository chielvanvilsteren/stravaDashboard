{
  "name": "strava-conditie",
  "version": "1.0.0",
  "description": "PWA voor conditie-analyse op basis van Strava-activiteiten",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build client",
    "start": "node server/index.js",
    "register-webhook": "node scripts/register-webhook.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "axios": "^1.7.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^0.20.0"
  }
}
