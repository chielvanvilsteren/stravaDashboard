# Environment — kopieer naar .env en vul echte waarden in
# NOOIT echte waarden in dit bestand opslaan — commit alleen .env.example

NODE_ENV=production

# ─── Supabase (server-only) ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # ALLEEN op de server, NOOIT naar client

# ─── Supabase (client-safe, VITE_ prefix) ────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=              # Vite bundelt alleen VITE_* variabelen

# ─── Strava ───────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=                # ALLEEN op de server
STRAVA_WEBHOOK_VERIFY_TOKEN=         # random string, minimaal 32 tekens

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=                      # random string, minimaal 64 tekens

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://jouw-app.onrender.com

# ─── Encryptie ────────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=                # 32 bytes hex (openssl rand -hex 32)
